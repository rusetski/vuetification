{
  "name": "vuetification",
  "version": "0.8.3",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vuetification.umd.cjs",
  "module": "./dist/vuetification.js",
  "exports": {
    ".": {
      "types": "./dist/vuetification.d.ts",
      "import": "./dist/vuetification.js",
      "require": "./dist/vuetification.umd.cjs"
    },
    "./style.css": "./dist/vuetification.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rusetski/vuetification.git"
  },
  "homepage": "https://rusetski.github.io/vuetification",
  "license": "MIT",
  "keywords": [
    "vuetification"
  ]
}
